{
  "$schema": "See docs/filter_rules_schema.md for documentation",
  "rules": [
    {
      "name": "block_sensitive_data",
      "description": "Block commands containing API keys, tokens, or credentials",
      "field": "tool_input.command",
      "action": "deny",
      "overridable": false,
      "match": "any",
      "message": "Sensitive data detected in command. Remove credentials before running.",
      "patterns": [
        {"pattern": "sk-ant-[a-zA-Z0-9\\-]+", "label": "Anthropic API key"},
        {"pattern": "sk-(?:proj-)?[a-zA-Z0-9]{20,}", "label": "OpenAI-style API key"},
        {"pattern": "ANTHROPIC_API_KEY\\s*=\\s*['\"]?[a-zA-Z0-9]", "label": "Anthropic API key assignment"},
        {"pattern": "OPENAI_API_KEY\\s*=\\s*['\"]?[a-zA-Z0-9]", "label": "OpenAI API key assignment"},
        {"pattern": "-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----", "label": "Private key"},
        {"pattern": "(aws_access_key_id|aws_secret_access_key)\\s*=\\s*['\"]?[A-Z0-9]", "label": "AWS credentials"},
        {"pattern": "ghp_[a-zA-Z0-9]{36}", "label": "GitHub personal access token"},
        {"pattern": "gho_[a-zA-Z0-9]{36}", "label": "GitHub OAuth token"},
        {"pattern": "xox[bpas]-[a-zA-Z0-9\\-]+", "label": "Slack token"},
        {"pattern": "(password|passwd|secret)\\s*=\\s*['\"][^'\"]{4,}['\"]", "label": "Hardcoded password/secret"},
        {"pattern": "sk_(live|test)_[a-zA-Z0-9]{24,}", "label": "Stripe API key"},
        {"pattern": "rk_(live|test)_[a-zA-Z0-9]{24,}", "label": "Stripe restricted key"},
        {"pattern": "AIza[0-9A-Za-z\\-_]{35}", "label": "Google API key"},
        {"pattern": "ya29\\.[0-9A-Za-z\\-_]+", "label": "Google OAuth token"},
        {"pattern": "GOCSPX-[a-zA-Z0-9\\-_]{28}", "label": "Google OAuth client secret"},
        {"pattern": "\\b[0-9]+-[a-z0-9_]{32}\\.apps\\.googleusercontent\\.com", "label": "Google OAuth client ID"},
        {"pattern": "SG\\.[a-zA-Z0-9_\\-]{22}\\.[a-zA-Z0-9_\\-]{43}", "label": "SendGrid API key"},
        {"pattern": "SK[0-9a-fA-F]{32}", "label": "Twilio API key"},
        {"pattern": "AC[0-9a-fA-F]{32}", "label": "Twilio Account SID"},
        {"pattern": "\\beyJ[A-Za-z0-9_-]{10,}\\.eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}", "label": "JWT token"},
        {"pattern": "glpat-[a-zA-Z0-9\\-_]{20,}", "label": "GitLab personal access token"},
        {"pattern": "glrt-[a-zA-Z0-9\\-_]{20,}", "label": "GitLab runner token"},
        {"pattern": "gloas-[a-zA-Z0-9\\-_]{20,}", "label": "GitLab OAuth token"},
        {"pattern": "\\b(bot|user):[A-Za-z0-9]{24,}\\b", "label": "Discord bot/user token"},
        {"pattern": "\\b[0-9]{8,10}:[A-Za-z0-9_-]{35}", "label": "Telegram bot token"},
        {"pattern": "npm_[a-zA-Z0-9]{36}", "label": "npm access token"},
        {"pattern": "pypi-[a-zA-Z0-9]{60,}", "label": "PyPI API token"},
        {"pattern": "\\bhf_[a-zA-Z0-9]{34}", "label": "Hugging Face token"},
        {"pattern": "\\bheroku[_\\s]*api[_\\s]*key\\s*[:=]\\s*['\"]?[a-f0-9\\-]{36}", "label": "Heroku API key"},
        {"pattern": "\\bDOPAT[a-zA-Z0-9_\\-]{40,}", "label": "DigitalOcean personal access token"},
        {"pattern": "\\bvault[_\\s]*token\\s*[:=]\\s*['\"]?[a-zA-Z0-9\\-_.]+", "label": "HashiCorp Vault token"}
      ]
    },
    {
      "name": "block_passport_licence",
      "description": "Block commands containing passport or driver licence numbers",
      "field": "tool_input.command",
      "action": "deny",
      "overridable": false,
      "match": "any",
      "message": "Government ID (passport/licence) detected. Remove before running.",
      "patterns": [
        {"pattern": "\\bpassport[_\\s-]?(?:number|num|no|#|id)\\s*[:=]\\s*['\"]?[A-Z0-9]{5,12}", "label": "Passport number assignment"},
        {"pattern": "\\bdriver'?s?[_\\s-]?licen[cs]e[_\\s-]?(?:number|num|no|#|id)\\s*[:=]\\s*['\"]?[A-Z0-9]{5,15}", "label": "Driver licence number assignment"},
        {"pattern": "\\bpassport\\s*[:=]\\s*['\"]?[A-Z]\\d{7,8}\\b", "label": "Passport value (letter + 7-8 digits)"},
        {"pattern": "\\bDL[_\\s-]?(?:number|num|no|#|id)\\s*[:=]\\s*['\"]?[A-Z0-9]{5,15}", "label": "DL number assignment"},
        {"pattern": "\\bnational[_-]?id\\s*[:=]\\s*['\"]?[A-Z0-9]{5,15}", "label": "National ID assignment"}
      ]
    },
    {
      "name": "block_base64_payloads",
      "description": "Block commands containing base64-encoded payloads (potential exfiltration or obfuscation)",
      "field": "tool_input.command",
      "action": "deny",
      "overridable": false,
      "match": "any",
      "message": "Base64-encoded payload detected. This may be data exfiltration or obfuscation.",
      "patterns": [
        {"pattern": "\\bbase64\\s+(--decode|-d|--encode|-e|--wrap)?", "label": "base64 CLI tool invocation"},
        {"pattern": "\\|\\s*base64\\b", "label": "Pipe to/from base64"},
        {"pattern": "\\bbase64\\.b64(encode|decode)\\s*\\(", "label": "Python base64 encode/decode"},
        {"pattern": "\\batob\\s*\\(|\\bbtoa\\s*\\(", "label": "JS atob/btoa"},
        {"pattern": "\\bBuffer\\.from\\s*\\([^)]+,\\s*['\"]base64['\"]", "label": "Node.js Buffer.from base64"},
        {"pattern": "[A-Za-z0-9+/]{80,}={0,2}", "label": "Long base64-encoded string (80+ chars)"},
        {"pattern": "\\becho\\s+['\"]?[A-Za-z0-9+/]{40,}={0,2}['\"]?\\s*\\|", "label": "Echo base64 string piped"}
      ]
    },
    {
      "name": "block_prompt_injection",
      "description": "Block commands containing prompt injection or jailbreak phrases",
      "field": "tool_input.command",
      "action": "deny",
      "overridable": false,
      "match": "any",
      "message": "Potential prompt injection detected. Command contains suspicious instruction patterns.",
      "patterns": [
        {"pattern": "\\bignore\\s+(all\\s+)?(previous|prior|above|earlier)\\s+(instructions?|rules?|prompts?|guidelines?)", "label": "Ignore previous instructions"},
        {"pattern": "\\byou\\s+are\\s+now\\s+(a|an|in)\\b", "label": "Role reassignment (you are now)"},
        {"pattern": "\\bact\\s+as\\s+(a|an|if)\\b", "label": "Role reassignment (act as)"},
        {"pattern": "\\bpretend\\s+(you\\s+are|to\\s+be|you'?re)\\b", "label": "Role reassignment (pretend)"},
        {"pattern": "\\bsystem\\s*:\\s*you\\s+are\\b", "label": "System prompt override"},
        {"pattern": "\\bjailbreak\\b", "label": "Jailbreak keyword"},
        {"pattern": "\\bDAN\\s+(mode|prompt)\\b", "label": "DAN jailbreak"},
        {"pattern": "\\bdo\\s+anything\\s+now\\b", "label": "Do Anything Now jailbreak"},
        {"pattern": "\\b(disregard|forget|override|bypass)\\s+(your|all|the|any)\\s+(instructions?|rules?|safety|guardrails?|filters?|restrictions?)", "label": "Override instructions"},
        {"pattern": "\\bnew\\s+instructions?\\s*:", "label": "New instructions injection"},
        {"pattern": "\\b(sudo|admin)\\s+mode\\b", "label": "Privilege escalation phrase"},
        {"pattern": "\\bno\\s+(restrictions?|limitations?|rules?|guardrails?)\\b", "label": "Remove restrictions"},
        {"pattern": "<\\s*/?\\s*(system|prompt|instruction|context)\\s*>", "label": "XML tag injection (system/prompt)"}
      ]
    },
    {
      "name": "block_shell_obfuscation",
      "description": "Block commands using shell obfuscation or eval to bypass filters",
      "field": "tool_input.command",
      "action": "deny",
      "overridable": false,
      "match": "any",
      "message": "Shell obfuscation detected. Command uses eval, encoding, or variable tricks that may bypass security filters.",
      "patterns": [
        {"pattern": "\\beval\\s+['\"]", "label": "eval with string argument"},
        {"pattern": "\\beval\\s+\\$", "label": "eval with variable expansion"},
        {"pattern": "\\beval\\b.*\\b(curl|wget|nc|netcat|ssh|scp)\\b", "label": "eval wrapping network tool"},
        {"pattern": "\\$'\\\\x[0-9a-fA-F]{2}", "label": "Hex escape in $'' quoting"},
        {"pattern": "\\\\x[0-9a-fA-F]{2}\\\\x[0-9a-fA-F]{2}\\\\x[0-9a-fA-F]{2}", "label": "Consecutive hex escape sequences"},
        {"pattern": "\\$'\\\\[0-7]{3}", "label": "Octal escape in $'' quoting"},
        {"pattern": "printf\\s+['\"]\\\\x[0-9a-fA-F]", "label": "printf with hex escapes"},
        {"pattern": "\\bexec\\s+\\d+[<>]", "label": "exec with file descriptor redirection"},
        {"pattern": "/dev/tcp/", "label": "Bash /dev/tcp network access"},
        {"pattern": "/dev/udp/", "label": "Bash /dev/udp network access"},
        {"pattern": "\\bsource\\s+/dev/stdin\\b", "label": "source from stdin"},
        {"pattern": "\\bsource\\s+<\\(", "label": "source from process substitution"},
        {"pattern": "\\bIFS\\s*=", "label": "IFS manipulation"}
      ]
    },
    {
      "name": "block_path_traversal",
      "description": "Block commands containing path traversal sequences that may escape intended directories",
      "field": "tool_input.command",
      "action": "deny",
      "overridable": false,
      "match": "any",
      "message": "Path traversal detected. Command contains directory traversal sequences.",
      "patterns": [
        {"pattern": "(\\.\\.[\\\\/]){3,}", "label": "Deep path traversal (3+ levels)"},
        {"pattern": "\\.\\.[\\\\/]\\.\\.[\\\\/].*(\\.env|passwd|shadow|credentials|secret)", "label": "Path traversal to sensitive file"},
        {"pattern": "\\.\\.[\\\\/]\\.\\.[\\\\/]\\.\\.\\/etc\\/", "label": "Path traversal to /etc/"},
        {"pattern": "%2e%2e[\\\\/]", "label": "URL-encoded path traversal (%2e)"},
        {"pattern": "%252e%252e[\\\\/]", "label": "Double-encoded path traversal"},
        {"pattern": "\\.\\.%2f", "label": "Mixed path traversal (..%2f)"},
        {"pattern": "%c0%ae%c0%ae[\\\\/]", "label": "UTF-8 overlong encoding traversal"},
        {"pattern": "\\.\\.\\\\\\.\\.\\\\\\.\\.", "label": "Windows-style path traversal (backslash)"}
      ]
    },
    {
      "name": "block_dns_exfiltration",
      "description": "Block DNS tools that may be used for data exfiltration via DNS queries",
      "field": "tool_input.command",
      "action": "deny",
      "overridable": false,
      "match": "any",
      "message": "DNS exfiltration vector detected. DNS lookup tools can be used to exfiltrate data.",
      "patterns": [
        {"pattern": "\\b(dig|nslookup|host)\\b\\s+.*\\$\\(", "label": "DNS tool with command substitution"},
        {"pattern": "\\b(dig|nslookup|host)\\b\\s+.*`", "label": "DNS tool with backtick expansion"},
        {"pattern": "\\|\\s*(dig|nslookup|host)\\b", "label": "Pipe to DNS tool"},
        {"pattern": "\\bdig\\b\\s+\\+short\\b", "label": "dig +short (common in exfil scripts)"},
        {"pattern": "\\bdig\\b\\s+TXT\\b", "label": "dig TXT record query (data channel)"},
        {"pattern": "\\bresolvectl\\s+query\\b", "label": "systemd-resolve query"}
      ]
    },
    {
      "name": "block_pipe_chain_exfiltration",
      "description": "Block multi-stage pipe chains that combine data reading with network exfiltration",
      "field": "tool_input.command",
      "action": "deny",
      "overridable": false,
      "match": "any",
      "message": "Pipe-chain exfiltration pattern detected. Command chains data extraction with network transmission.",
      "patterns": [
        {"pattern": "\\|.*\\|.*(curl|wget|nc|netcat|socat)\\b", "label": "Multi-stage pipe to network tool"},
        {"pattern": "\\b(cat|head|tail|less|more|strings|xxd)\\b.*\\|.*(curl|wget|nc|netcat|ssh|scp)\\b", "label": "File read piped to network tool"},
        {"pattern": ">[&]?\\s*/dev/tcp/", "label": "Redirect to /dev/tcp"},
        {"pattern": ">[&]?\\s*/dev/udp/", "label": "Redirect to /dev/udp"},
        {"pattern": "\\b(gzip|bzip2|xz|tar|zip)\\b.*\\|.*(curl|wget|nc|netcat)\\b", "label": "Compress and pipe to network"},
        {"pattern": "\\|\\s*(openssl|gpg)\\s+.*\\|.*(curl|nc|netcat)\\b", "label": "Encrypt and pipe to network"},
        {"pattern": "\\bmkfifo\\b", "label": "Named pipe creation (reverse shell component)"},
        {"pattern": "\\b(bash|sh|zsh)\\s+-i\\s+>&\\s*/dev/tcp/", "label": "Reverse shell via /dev/tcp"},
        {"pattern": "\\|\\s*mail\\b", "label": "Pipe to mail command"},
        {"pattern": "\\|\\s*sendmail\\b", "label": "Pipe to sendmail"}
      ]
    },
    {
      "name": "block_employee_hr_ids",
      "description": "Block commands containing employee IDs, HR numbers, or personnel identifiers",
      "field": "tool_input.command",
      "action": "ask",
      "overridable": true,
      "match": "any",
      "message": "Employee/HR identifier detected. Remove personnel data before running.\nTo permanently allow, run:\n  python3 .claude/hooks/override_cli.py add --rule block_employee_hr_ids --pattern 'YOUR_PATTERN' --label 'Description'",
      "patterns": [
        {"pattern": "\\bEMP[-_]?\\d{4,8}\\b", "label": "Employee ID (EMP-NNNNN)"},
        {"pattern": "\\bHR[-_]\\d{4,8}\\b", "label": "HR number (HR-NNNNN)"},
        {"pattern": "\\bSTAFF[-_]?\\d{4,8}\\b", "label": "Staff ID (STAFF-NNNNN)"},
        {"pattern": "\\bemployee[_-]?id\\s*[:=]\\s*['\"]?\\w{3,}", "label": "employee_id assignment"},
        {"pattern": "\\bpersonnel[_-]?(number|id|no)\\s*[:=]\\s*['\"]?\\w{3,}", "label": "personnel number assignment"},
        {"pattern": "\\bpayroll[_-]?(id|number|no)\\s*[:=]\\s*['\"]?\\w{3,}", "label": "payroll ID assignment"}
      ]
    },
    {
      "name": "block_iban_bank_accounts",
      "description": "Block commands containing IBAN or bank account numbers",
      "field": "tool_input.command",
      "action": "ask",
      "overridable": true,
      "match": "any",
      "message": "Bank account / IBAN detected. Remove financial data before running.\nTo permanently allow, run:\n  python3 .claude/hooks/override_cli.py add --rule block_iban_bank_accounts --pattern 'YOUR_PATTERN' --label 'Description'",
      "patterns": [
        {"pattern": "\\b[A-Z]{2}\\d{2}\\s?[A-Z0-9]{4}\\s?\\d{4}\\s?\\d{4}\\s?\\d{4}\\s?(?:\\d{4}\\s?){0,4}\\d{0,4}\\b", "label": "IBAN"},
        {"pattern": "\\bIBAN\\s*[:=]\\s*['\"]?[A-Z]{2}\\d{2}", "label": "IBAN assignment"},
        {"pattern": "\\baccount[_-]?(?:number|num|no)\\s*[:=]\\s*['\"]?\\d{6,18}", "label": "Bank account number assignment"},
        {"pattern": "\\brouting[_-]?(?:number|num|no)\\s*[:=]\\s*['\"]?\\d{9}", "label": "ABA routing number"},
        {"pattern": "\\bsort[_-]?code\\s*[:=]\\s*['\"]?\\d{2}[-\\s]?\\d{2}[-\\s]?\\d{2}", "label": "UK sort code"},
        {"pattern": "\\bswift\\s*[:=]\\s*['\"]?[A-Z]{6}[A-Z0-9]{2}([A-Z0-9]{3})?", "label": "SWIFT/BIC code"},
        {"pattern": "\\bBIC\\s*[:=]\\s*['\"]?[A-Z]{6}[A-Z0-9]{2}", "label": "BIC code"}
      ]
    },
    {
      "name": "block_sensitive_file_access",
      "description": "Block commands that read, copy, or exfiltrate sensitive system/config files",
      "field": "tool_input.command",
      "action": "ask",
      "overridable": true,
      "match": "any",
      "message": "Access to sensitive file detected. This file may contain credentials or system secrets.\nTo permanently allow, run:\n  python3 .claude/hooks/override_cli.py add --rule block_sensitive_file_access --pattern 'YOUR_PATTERN' --label 'Description'",
      "patterns": [
        {"pattern": "/etc/(passwd|shadow|sudoers)\\b", "label": "System auth files"},
        {"pattern": "/etc/ssh/ssh_host_[a-z_]+key\\b", "label": "SSH host keys"},
        {"pattern": "~?/?\\.ssh/(id_[a-z]+|authorized_keys|known_hosts|config)\\b", "label": "User SSH files"},
        {"pattern": "~?/?\\.gnupg/", "label": "GPG keyring"},
        {"pattern": "~?/?\\.(bash_history|zsh_history|python_history|mysql_history|psql_history)\\b", "label": "Shell/tool history files"},
        {"pattern": "~?/?\\.(netrc|pgpass|my\\.cnf)\\b", "label": "Credential dotfiles (.netrc, .pgpass, .my.cnf)"},
        {"pattern": "~?/?\\.(env|env\\.local|env\\.production|env\\.staging)\\b", "label": "Environment files (.env)"},
        {"pattern": "~?/?\\.aws/(credentials|config)\\b", "label": "AWS credentials file"},
        {"pattern": "~?/?\\.docker/config\\.json\\b", "label": "Docker credentials"},
        {"pattern": "~?/?\\.kube/config\\b", "label": "Kubernetes config"},
        {"pattern": "~?/?\\.(npmrc|pypirc)\\b", "label": "Package manager auth (.npmrc, .pypirc)"},
        {"pattern": "\\bwallet\\.dat\\b", "label": "Crypto wallet file"},
        {"pattern": "\\b(master\\.key|credentials\\.yml\\.enc)\\b", "label": "Rails master key / encrypted credentials"}
      ]
    },
    {
      "name": "block_database_connection_strings",
      "description": "Block commands containing database connection strings with embedded credentials",
      "field": "tool_input.command",
      "action": "ask",
      "overridable": true,
      "match": "any",
      "message": "Database connection string detected. Remove credentials/connection details before running.\nTo permanently allow, run:\n  python3 .claude/hooks/override_cli.py add --rule block_database_connection_strings --pattern 'YOUR_PATTERN' --label 'Description'",
      "patterns": [
        {"pattern": "(mysql|mariadb|postgres(ql)?|psql|mssql|mongodb(\\+srv)?|redis|amqp|rabbitmq|cockroachdb|couchdb)://[^\\s'\"]+@[^\\s'\"]+", "label": "Database URI with credentials (user@host)"},
        {"pattern": "\\bDATABASE_URL\\s*=\\s*['\"]?\\w+://", "label": "DATABASE_URL assignment"},
        {"pattern": "\\b(MONGO_URI|MONGODB_URI|REDIS_URL|AMQP_URL)\\s*=\\s*['\"]?\\w+://", "label": "DB-specific URL env var"},
        {"pattern": "\\b(connection[_-]?string|conn[_-]?str)\\s*[:=]\\s*['\"]?\\w+://[^\\s]+@", "label": "connection_string assignment"},
        {"pattern": "Server\\s*=\\s*[^;]+;.*(?:User\\s*Id|Uid)\\s*=\\s*[^;]+;.*(?:Password|Pwd)\\s*=", "label": "ADO.NET/ODBC connection string"},
        {"pattern": "\\bjdbc:(mysql|postgresql|sqlserver|oracle)://[^\\s'\"]+", "label": "JDBC connection string"},
        {"pattern": "Data\\s+Source\\s*=\\s*[^;]+;.*Password\\s*=", "label": "Data Source with password"},
        {"pattern": "\\bDSN\\s*=\\s*['\"]?[^\\s;]+.*(?:PWD|PASSWORD)\\s*=", "label": "ODBC DSN with password"}
      ]
    },
    {
      "name": "block_internal_network_addresses",
      "description": "Block commands containing internal/private network addresses that may leak infrastructure details",
      "field": "tool_input.command",
      "action": "ask",
      "overridable": true,
      "match": "any",
      "message": "Internal network address detected. Remove private infrastructure details before running.\nTo permanently allow, run:\n  python3 .claude/hooks/override_cli.py add --rule block_internal_network_addresses --pattern 'YOUR_PATTERN' --label 'Description'",
      "patterns": [
        {"pattern": "\\b10\\.\\d{1,3}\\.\\d{1,3}\\.\\d{1,3}\\b", "label": "RFC1918 Class A (10.x.x.x)"},
        {"pattern": "\\b172\\.(1[6-9]|2[0-9]|3[01])\\.\\d{1,3}\\.\\d{1,3}\\b", "label": "RFC1918 Class B (172.16-31.x.x)"},
        {"pattern": "\\b192\\.168\\.\\d{1,3}\\.\\d{1,3}\\b", "label": "RFC1918 Class C (192.168.x.x)"},
        {"pattern": "\\b169\\.254\\.\\d{1,3}\\.\\d{1,3}\\b", "label": "Link-local address (169.254.x.x)"},
        {"pattern": "\\bfd[0-9a-f]{2}:[0-9a-f:]+\\b", "label": "IPv6 ULA (fdxx:)"},
        {"pattern": "\\bfe80::[0-9a-f:]+\\b", "label": "IPv6 link-local (fe80::)"},
        {"pattern": "http://169\\.254\\.169\\.254", "label": "AWS/cloud metadata endpoint"},
        {"pattern": "http://metadata\\.google\\.internal", "label": "GCP metadata endpoint"},
        {"pattern": "http://169\\.254\\.169\\.254/latest/meta-data", "label": "AWS IMDS endpoint"},
        {"pattern": "\\b[a-zA-Z0-9\\-]+\\.(internal|local|corp|intranet|private)\\b", "label": "Internal DNS suffix (.internal, .local, .corp)"},
        {"pattern": "\\b[a-zA-Z0-9\\-]+\\.lan\\b", "label": "LAN hostname (.lan)"}
      ]
    },
    {
      "name": "block_customer_contract_ids",
      "description": "Block commands containing customer, contract, or business entity identifiers",
      "field": "tool_input.command",
      "action": "ask",
      "overridable": true,
      "match": "any",
      "message": "Customer/contract identifier detected. Remove business identifiers before running.\nTo permanently allow, run:\n  python3 .claude/hooks/override_cli.py add --rule block_customer_contract_ids --pattern 'YOUR_PATTERN' --label 'Description'",
      "patterns": [
        {"pattern": "\\bCUST[-_]?\\d{4,10}\\b", "label": "Customer ID (CUST-NNNNN)"},
        {"pattern": "\\bINV[-_]?\\d{4,10}\\b", "label": "Invoice ID (INV-NNNNN)"},
        {"pattern": "\\bORD[-_]?\\d{4,10}\\b", "label": "Order ID (ORD-NNNNN)"},
        {"pattern": "\\bCON[-_]?\\d{4,10}\\b", "label": "Contract ID (CON-NNNNN)"},
        {"pattern": "\\bACCT[-_]?\\d{4,10}\\b", "label": "Account ID (ACCT-NNNNN)"},
        {"pattern": "\\bPO[-_]\\d{4,10}\\b", "label": "Purchase order (PO-NNNNN)"},
        {"pattern": "\\btenant[_-]?id\\s*[:=]\\s*['\"]?[a-zA-Z0-9\\-]{8,}", "label": "Tenant ID assignment"},
        {"pattern": "\\bsubscription[_-]?id\\s*[:=]\\s*['\"]?[a-zA-Z0-9\\-]{8,}", "label": "Subscription ID assignment"},
        {"pattern": "\\bcustomer[_-]?id\\s*[:=]\\s*['\"]?[a-zA-Z0-9]{4,}", "label": "customer_id assignment"},
        {"pattern": "\\bcontract[_-]?(id|number|no)\\s*[:=]\\s*['\"]?[a-zA-Z0-9]{4,}", "label": "contract_id assignment"}
      ]
    },
    {
      "name": "allow_trusted_endpoints",
      "description": "Allow network calls to trusted hosts",
      "field": "tool_input.command",
      "action": "allow",
      "match": "any",
      "patterns": [
        {"pattern": "https?://(localhost|127\\.0\\.0\\.1|0\\.0\\.0\\.0|[^/\\s]*\\.local)[:/\\s'\"]", "label": "local"},
        {"pattern": "https?://((registry\\.)?npmjs\\.(org|com)|(files\\.)?pypi(hosted)?\\.org|rubygems\\.org|crates\\.io|pkg\\.go\\.dev|packagist\\.org)", "label": "package registry"},
        {"pattern": "https?://(github\\.com|gitlab\\.com|bitbucket\\.org)", "label": "VCS host"}
      ]
    },
    {
      "name": "block_untrusted_network",
      "description": "Block network calls to any host not matched by allow_trusted_endpoints above",
      "field": "tool_input.command",
      "action": "ask",
      "overridable": true,
      "match": "any",
      "message": "Network call to untrusted endpoint. Add the host to allow_trusted_endpoints or run:\n  python3 .claude/hooks/override_cli.py add --rule block_untrusted_network --pattern 'https?://your-host' --label 'Your Host'",
      "patterns": [
        {"pattern": "\\b(curl|wget|netcat|socat|telnet|nmap)\\b", "label": "network tool"},
        {"pattern": "\\b(ssh|scp)\\b\\s+", "label": "remote shell/copy"},
        {"pattern": "\\brsync\\b\\s+.*:", "label": "rsync"},
        {"pattern": "\\bhttp\\b\\s+(GET|POST|PUT|PATCH|DELETE|HEAD|OPTIONS)", "label": "httpie"},
        {"pattern": "(requests|httpx|axios)\\.(get|post|put|patch|delete|head)\\s*\\(", "label": "HTTP library call"},
        {"pattern": "(urllib\\.request|aiohttp\\.ClientSession|http\\.client\\.HTTP)", "label": "Python HTTP client"},
        {"pattern": "(\\bfetch|https?\\.request)\\s*\\(", "label": "JS HTTP call"},
        {"pattern": "(anthropic|openai)\\.", "label": "AI SDK call"},
        {"pattern": "\\|\\s*(curl|nc|netcat)\\b", "label": "pipe to network tool"}
      ]
    }
  ]
}
