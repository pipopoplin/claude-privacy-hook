{
  "$schema": "See docs/filter_rules_schema.md for documentation",
  "rules": [
    {
      "name": "block_api_keys_in_content",
      "description": "Block Write/Edit operations containing API keys or tokens",
      "field": "tool_input.content",
      "tool_name": "Write|Edit",
      "action": "deny",
      "overridable": false,
      "match": "any",
      "message": "Sensitive data detected in file content. Remove credentials before writing.",
      "patterns": [
        {"pattern": "sk-ant-[a-zA-Z0-9\\-]+", "label": "Anthropic API key"},
        {"pattern": "sk-(?:proj-)?[a-zA-Z0-9]{20,}", "label": "OpenAI-style API key"},
        {"pattern": "ghp_[a-zA-Z0-9]{36}", "label": "GitHub personal access token"},
        {"pattern": "gho_[a-zA-Z0-9]{36}", "label": "GitHub OAuth token"},
        {"pattern": "xox[bpas]-[a-zA-Z0-9\\-]+", "label": "Slack token"},
        {"pattern": "sk_(live|test)_[a-zA-Z0-9]{24,}", "label": "Stripe API key"},
        {"pattern": "rk_(live|test)_[a-zA-Z0-9]{24,}", "label": "Stripe restricted key"},
        {"pattern": "AIza[0-9A-Za-z\\-_]{35}", "label": "Google API key"},
        {"pattern": "ya29\\.[0-9A-Za-z\\-_]+", "label": "Google OAuth token"},
        {"pattern": "GOCSPX-[a-zA-Z0-9\\-_]{28}", "label": "Google OAuth client secret"},
        {"pattern": "SG\\.[a-zA-Z0-9_\\-]{22}\\.[a-zA-Z0-9_\\-]{43}", "label": "SendGrid API key"},
        {"pattern": "SK[0-9a-fA-F]{32}", "label": "Twilio API key"},
        {"pattern": "AC[0-9a-fA-F]{32}", "label": "Twilio Account SID"},
        {"pattern": "glpat-[a-zA-Z0-9\\-_]{20,}", "label": "GitLab personal access token"},
        {"pattern": "npm_[a-zA-Z0-9]{36}", "label": "npm access token"},
        {"pattern": "pypi-[a-zA-Z0-9]{60,}", "label": "PyPI API token"},
        {"pattern": "\\bhf_[a-zA-Z0-9]{34}", "label": "Hugging Face token"},
        {"pattern": "\\bDOPAT[a-zA-Z0-9_\\-]{40,}", "label": "DigitalOcean personal access token"},
        {"pattern": "(aws_access_key_id|aws_secret_access_key)\\s*=\\s*['\"]?[A-Z0-9]", "label": "AWS credentials"},
        {"pattern": "ANTHROPIC_API_KEY\\s*=\\s*['\"]?[a-zA-Z0-9]", "label": "Anthropic API key assignment"},
        {"pattern": "OPENAI_API_KEY\\s*=\\s*['\"]?[a-zA-Z0-9]", "label": "OpenAI API key assignment"},
        {"pattern": "\\beyJ[A-Za-z0-9_-]{10,}\\.eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}", "label": "JWT token"},
        {"pattern": "\\b[0-9]{8,10}:[A-Za-z0-9_-]{35}", "label": "Telegram bot token"}
      ]
    },
    {
      "name": "block_private_keys_in_content",
      "description": "Block Write/Edit operations containing private keys",
      "field": "tool_input.content",
      "tool_name": "Write|Edit",
      "action": "deny",
      "overridable": false,
      "match": "any",
      "message": "Private key detected in file content. Do not write private keys to files.",
      "patterns": [
        {"pattern": "-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----", "label": "Private key block"}
      ]
    },
    {
      "name": "block_hardcoded_passwords_in_content",
      "description": "Block Write/Edit operations containing hardcoded passwords or secrets",
      "field": "tool_input.content",
      "tool_name": "Write|Edit",
      "action": "deny",
      "overridable": false,
      "match": "any",
      "message": "Hardcoded password or secret detected. Use environment variables or a secrets manager instead.",
      "patterns": [
        {"pattern": "(password|passwd|secret)\\s*=\\s*['\"][^'\"]{4,}['\"]", "label": "Hardcoded password/secret"},
        {"pattern": "\\bvault[_\\s]*token\\s*[:=]\\s*['\"]?[a-zA-Z0-9\\-_.]+", "label": "HashiCorp Vault token"},
        {"pattern": "\\bheroku[_\\s]*api[_\\s]*key\\s*[:=]\\s*['\"]?[a-f0-9\\-]{36}", "label": "Heroku API key"}
      ]
    },
    {
      "name": "block_database_connection_strings_in_content",
      "description": "Block Write/Edit operations containing database connection strings with credentials",
      "field": "tool_input.content",
      "tool_name": "Write|Edit",
      "action": "deny",
      "overridable": false,
      "match": "any",
      "message": "Database connection string detected. Use environment variables for database credentials.",
      "patterns": [
        {"pattern": "(mysql|mariadb|postgres(ql)?|psql|mssql|mongodb(\\+srv)?|redis|amqp|rabbitmq|cockroachdb|couchdb)://[^\\s'\"]+@[^\\s'\"]+", "label": "Database URI with credentials"},
        {"pattern": "\\bDATABASE_URL\\s*=\\s*['\"]?\\w+://", "label": "DATABASE_URL assignment"},
        {"pattern": "\\b(MONGO_URI|MONGODB_URI|REDIS_URL|AMQP_URL)\\s*=\\s*['\"]?\\w+://", "label": "DB-specific URL env var"},
        {"pattern": "Server\\s*=\\s*[^;]+;.*(?:User\\s*Id|Uid)\\s*=\\s*[^;]+;.*(?:Password|Pwd)\\s*=", "label": "ADO.NET/ODBC connection string"},
        {"pattern": "\\bjdbc:(mysql|postgresql|sqlserver|oracle)://[^\\s'\"]+", "label": "JDBC connection string"},
        {"pattern": "Data\\s+Source\\s*=\\s*[^;]+;.*Password\\s*=", "label": "Data Source with password"}
      ]
    },
    {
      "name": "block_ssn_in_content",
      "description": "Block Write/Edit operations containing Social Security Numbers",
      "field": "tool_input.content",
      "tool_name": "Write|Edit",
      "action": "deny",
      "overridable": false,
      "match": "any",
      "message": "Social Security Number detected. Remove PII before writing to files.",
      "patterns": [
        {"pattern": "\\b\\d{3}-\\d{2}-\\d{4}\\b", "label": "SSN (NNN-NN-NNNN format)"},
        {"pattern": "\\bSSN\\s*[:=]\\s*['\"]?\\d{3}[- ]?\\d{2}[- ]?\\d{4}", "label": "SSN assignment"},
        {"pattern": "\\bsocial[_\\s-]?security[_\\s-]?(number|num|no|#)?\\s*[:=]\\s*['\"]?\\d{3}", "label": "Social security number assignment"}
      ]
    },
    {
      "name": "block_credit_cards_in_content",
      "description": "Block Write/Edit operations containing credit card numbers",
      "field": "tool_input.content",
      "tool_name": "Write|Edit",
      "action": "deny",
      "overridable": false,
      "match": "any",
      "message": "Credit card number detected. Remove payment card data before writing to files.",
      "patterns": [
        {"pattern": "\\b4[0-9]{3}[- ]?[0-9]{4}[- ]?[0-9]{4}[- ]?[0-9]{4}\\b", "label": "Visa card number"},
        {"pattern": "\\b5[1-5][0-9]{2}[- ]?[0-9]{4}[- ]?[0-9]{4}[- ]?[0-9]{4}\\b", "label": "Mastercard number"},
        {"pattern": "\\b3[47][0-9]{2}[- ]?[0-9]{6}[- ]?[0-9]{5}\\b", "label": "Amex card number"},
        {"pattern": "\\b6(?:011|5[0-9]{2})[- ]?[0-9]{4}[- ]?[0-9]{4}[- ]?[0-9]{4}\\b", "label": "Discover card number"},
        {"pattern": "\\bcredit[_\\s-]?card[_\\s-]?(number|num|no|#)?\\s*[:=]\\s*['\"]?\\d{4}", "label": "Credit card assignment"},
        {"pattern": "\\bcard[_\\s-]?number\\s*[:=]\\s*['\"]?\\d{4}", "label": "Card number assignment"}
      ]
    },
    {
      "name": "block_internal_ips_in_content",
      "description": "Block Write/Edit operations containing internal/private IP addresses",
      "field": "tool_input.content",
      "tool_name": "Write|Edit",
      "action": "deny",
      "overridable": false,
      "match": "any",
      "message": "Internal network address detected. Remove private infrastructure details before writing.",
      "patterns": [
        {"pattern": "\\b10\\.\\d{1,3}\\.\\d{1,3}\\.\\d{1,3}\\b", "label": "RFC1918 Class A (10.x.x.x)"},
        {"pattern": "\\b172\\.(1[6-9]|2[0-9]|3[01])\\.\\d{1,3}\\.\\d{1,3}\\b", "label": "RFC1918 Class B (172.16-31.x.x)"},
        {"pattern": "\\b192\\.168\\.\\d{1,3}\\.\\d{1,3}\\b", "label": "RFC1918 Class C (192.168.x.x)"}
      ]
    },
    {
      "name": "block_api_keys_in_edit",
      "description": "Block Edit operations containing API keys in new_string field",
      "field": "tool_input.new_string",
      "tool_name": "Edit",
      "action": "deny",
      "overridable": false,
      "match": "any",
      "message": "Sensitive data detected in edit content. Remove credentials before editing.",
      "patterns": [
        {"pattern": "sk-ant-[a-zA-Z0-9\\-]+", "label": "Anthropic API key"},
        {"pattern": "sk-(?:proj-)?[a-zA-Z0-9]{20,}", "label": "OpenAI-style API key"},
        {"pattern": "ghp_[a-zA-Z0-9]{36}", "label": "GitHub personal access token"},
        {"pattern": "-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----", "label": "Private key block"},
        {"pattern": "(password|passwd|secret)\\s*=\\s*['\"][^'\"]{4,}['\"]", "label": "Hardcoded password/secret"},
        {"pattern": "(mysql|mariadb|postgres(ql)?|psql|mssql|mongodb(\\+srv)?|redis|amqp)://[^\\s'\"]+@[^\\s'\"]+", "label": "Database URI with credentials"},
        {"pattern": "\\b\\d{3}-\\d{2}-\\d{4}\\b", "label": "SSN (NNN-NN-NNNN format)"},
        {"pattern": "\\b4[0-9]{3}[- ]?[0-9]{4}[- ]?[0-9]{4}[- ]?[0-9]{4}\\b", "label": "Visa card number"},
        {"pattern": "\\b5[1-5][0-9]{2}[- ]?[0-9]{4}[- ]?[0-9]{4}[- ]?[0-9]{4}\\b", "label": "Mastercard number"},
        {"pattern": "(aws_access_key_id|aws_secret_access_key)\\s*=\\s*['\"]?[A-Z0-9]", "label": "AWS credentials"},
        {"pattern": "\\b10\\.\\d{1,3}\\.\\d{1,3}\\.\\d{1,3}\\b", "label": "RFC1918 Class A (10.x.x.x)"},
        {"pattern": "\\b192\\.168\\.\\d{1,3}\\.\\d{1,3}\\b", "label": "RFC1918 Class C (192.168.x.x)"}
      ]
    }
  ]
}
