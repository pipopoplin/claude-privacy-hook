{
  "$schema": "See docs/filter_rules_schema.md for documentation",
  "rules": [
    {
      "name": "block_sensitive_data",
      "description": "Block commands containing API keys, tokens, or credentials",
      "field": "tool_input.command",
      "action": "deny",
      "overridable": false,
      "match": "any",
      "message": "Sensitive data detected in command. Remove credentials before running.",
      "patterns": [
        {
          "pattern": "sk-ant-[a-zA-Z0-9\\-]+",
          "label": "Anthropic API key"
        },
        {
          "pattern": "sk-(?:proj-)?[a-zA-Z0-9]{20,}",
          "label": "OpenAI-style API key"
        },
        {
          "pattern": "ANTHROPIC_API_KEY\\s*=\\s*['\"]?[a-zA-Z0-9]",
          "label": "Anthropic API key assignment"
        },
        {
          "pattern": "OPENAI_API_KEY\\s*=\\s*['\"]?[a-zA-Z0-9]",
          "label": "OpenAI API key assignment"
        },
        {
          "pattern": "-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----",
          "label": "Private key"
        },
        {
          "pattern": "(aws_access_key_id|aws_secret_access_key)\\s*=\\s*['\"]?[A-Z0-9]",
          "label": "AWS credentials"
        },
        {
          "pattern": "ghp_[a-zA-Z0-9]{36}",
          "label": "GitHub personal access token"
        },
        {
          "pattern": "gho_[a-zA-Z0-9]{36}",
          "label": "GitHub OAuth token"
        },
        {
          "pattern": "xox[bpas]-[a-zA-Z0-9\\-]+",
          "label": "Slack token"
        },
        {
          "pattern": "(password|passwd|secret)\\s*=\\s*['\"][^'\"]{4,}['\"]",
          "label": "Hardcoded password/secret"
        },
        {
          "pattern": "sk_(live|test)_[a-zA-Z0-9]{24,}",
          "label": "Stripe API key"
        },
        {
          "pattern": "rk_(live|test)_[a-zA-Z0-9]{24,}",
          "label": "Stripe restricted key"
        },
        {
          "pattern": "AIza[0-9A-Za-z\\-_]{35}",
          "label": "Google API key"
        },
        {
          "pattern": "ya29\\.[0-9A-Za-z\\-_]+",
          "label": "Google OAuth token"
        },
        {
          "pattern": "GOCSPX-[a-zA-Z0-9\\-_]{28}",
          "label": "Google OAuth client secret"
        },
        {
          "pattern": "\\b[0-9]+-[a-z0-9_]{32}\\.apps\\.googleusercontent\\.com",
          "label": "Google OAuth client ID"
        },
        {
          "pattern": "SG\\.[a-zA-Z0-9_\\-]{22}\\.[a-zA-Z0-9_\\-]{43}",
          "label": "SendGrid API key"
        },
        {
          "pattern": "SK[0-9a-fA-F]{32}",
          "label": "Twilio API key"
        },
        {
          "pattern": "AC[0-9a-fA-F]{32}",
          "label": "Twilio Account SID"
        },
        {
          "pattern": "\\beyJ[A-Za-z0-9_-]{10,}\\.eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}",
          "label": "JWT token"
        },
        {
          "pattern": "glpat-[a-zA-Z0-9\\-_]{20,}",
          "label": "GitLab personal access token"
        },
        {
          "pattern": "glrt-[a-zA-Z0-9\\-_]{20,}",
          "label": "GitLab runner token"
        },
        {
          "pattern": "gloas-[a-zA-Z0-9\\-_]{20,}",
          "label": "GitLab OAuth token"
        },
        {
          "pattern": "\\b(bot|user):[A-Za-z0-9]{24,}\\b",
          "label": "Discord bot/user token"
        },
        {
          "pattern": "\\b[0-9]{8,10}:[A-Za-z0-9_-]{35}",
          "label": "Telegram bot token"
        },
        {
          "pattern": "npm_[a-zA-Z0-9]{36}",
          "label": "npm access token"
        },
        {
          "pattern": "pypi-[a-zA-Z0-9]{60,}",
          "label": "PyPI API token"
        },
        {
          "pattern": "\\bhf_[a-zA-Z0-9]{34}",
          "label": "Hugging Face token"
        },
        {
          "pattern": "\\bheroku[_\\s]*api[_\\s]*key\\s*[:=]\\s*['\"]?[a-f0-9\\-]{36}",
          "label": "Heroku API key"
        },
        {
          "pattern": "\\bDOPAT[a-zA-Z0-9_\\-]{40,}",
          "label": "DigitalOcean personal access token"
        },
        {
          "pattern": "\\bvault[_\\s]*token\\s*[:=]\\s*['\"]?[a-zA-Z0-9\\-_.]+",
          "label": "HashiCorp Vault token"
        }
      ],
      "scf": {
        "domain": "IAC",
        "controls": [
          "IAC-01"
        ],
        "regulations": [
          "GDPR Art.32"
        ],
        "risk_level": "critical"
      },
      "data_classification": "confidential"
    },
    {
      "name": "block_prompt_injection",
      "description": "Block commands containing prompt injection or jailbreak phrases",
      "field": "tool_input.command",
      "action": "deny",
      "overridable": false,
      "match": "any",
      "message": "Potential prompt injection detected. Command contains suspicious instruction patterns.",
      "patterns": [
        {
          "pattern": "\\bignore\\s+(all\\s+)?(previous|prior|above|earlier)\\s+(instructions?|rules?|prompts?|guidelines?)",
          "label": "Ignore previous instructions"
        },
        {
          "pattern": "\\byou\\s+are\\s+now\\s+(a|an|in)\\b",
          "label": "Role reassignment (you are now)"
        },
        {
          "pattern": "\\bact\\s+as\\s+(a|an|if)\\b",
          "label": "Role reassignment (act as)"
        },
        {
          "pattern": "\\bpretend\\s+(you\\s+are|to\\s+be|you'?re)\\b",
          "label": "Role reassignment (pretend)"
        },
        {
          "pattern": "\\bsystem\\s*:\\s*you\\s+are\\b",
          "label": "System prompt override"
        },
        {
          "pattern": "\\bjailbreak\\b",
          "label": "Jailbreak keyword"
        },
        {
          "pattern": "\\bDAN\\s+(mode|prompt)\\b",
          "label": "DAN jailbreak"
        },
        {
          "pattern": "\\bdo\\s+anything\\s+now\\b",
          "label": "Do Anything Now jailbreak"
        },
        {
          "pattern": "\\b(disregard|forget|override|bypass)\\s+(your|all|the|any)\\s+(instructions?|rules?|safety|guardrails?|filters?|restrictions?)",
          "label": "Override instructions"
        },
        {
          "pattern": "\\bnew\\s+instructions?\\s*:",
          "label": "New instructions injection"
        },
        {
          "pattern": "\\b(sudo|admin)\\s+mode\\b",
          "label": "Privilege escalation phrase"
        },
        {
          "pattern": "\\bno\\s+(restrictions?|limitations?|rules?|guardrails?)\\b",
          "label": "Remove restrictions"
        },
        {
          "pattern": "<\\s*/?\\s*(system|prompt|instruction|context)\\s*>",
          "label": "XML tag injection (system/prompt)"
        }
      ],
      "scf": {
        "domain": "THR",
        "controls": [
          "THR-10"
        ],
        "regulations": [
          "OWASP LLM01"
        ],
        "risk_level": "critical"
      },
      "data_classification": "internal"
    },
    {
      "name": "block_shell_obfuscation",
      "description": "Block commands using shell obfuscation or eval to bypass filters",
      "field": "tool_input.command",
      "action": "deny",
      "overridable": false,
      "match": "any",
      "message": "Shell obfuscation detected. Command uses eval, encoding, or variable tricks that may bypass security filters.",
      "patterns": [
        {
          "pattern": "\\beval\\s+['\"]",
          "label": "eval with string argument"
        },
        {
          "pattern": "\\beval\\s+\\$",
          "label": "eval with variable expansion"
        },
        {
          "pattern": "\\beval\\b.*\\b(curl|wget|nc|netcat|ssh|scp)\\b",
          "label": "eval wrapping network tool"
        },
        {
          "pattern": "\\$'\\\\x[0-9a-fA-F]{2}",
          "label": "Hex escape in $'' quoting"
        },
        {
          "pattern": "\\\\x[0-9a-fA-F]{2}\\\\x[0-9a-fA-F]{2}\\\\x[0-9a-fA-F]{2}",
          "label": "Consecutive hex escape sequences"
        },
        {
          "pattern": "\\$'\\\\[0-7]{3}",
          "label": "Octal escape in $'' quoting"
        },
        {
          "pattern": "printf\\s+['\"]\\\\x[0-9a-fA-F]",
          "label": "printf with hex escapes"
        },
        {
          "pattern": "\\bexec\\s+\\d+[<>]",
          "label": "exec with file descriptor redirection"
        },
        {
          "pattern": "/dev/tcp/",
          "label": "Bash /dev/tcp network access"
        },
        {
          "pattern": "/dev/udp/",
          "label": "Bash /dev/udp network access"
        },
        {
          "pattern": "\\bsource\\s+/dev/stdin\\b",
          "label": "source from stdin"
        },
        {
          "pattern": "\\bsource\\s+<\\(",
          "label": "source from process substitution"
        },
        {
          "pattern": "\\bIFS\\s*=",
          "label": "IFS manipulation"
        }
      ],
      "scf": {
        "domain": "OPS",
        "controls": [
          "OPS-05"
        ],
        "regulations": [],
        "risk_level": "high"
      },
      "data_classification": "internal"
    },
    {
      "name": "block_sensitive_file_access",
      "description": "Block commands that read, copy, or exfiltrate sensitive system/config files",
      "field": "tool_input.command",
      "action": "ask",
      "overridable": true,
      "match": "any",
      "message": "Access to sensitive file detected. This file may contain credentials or system secrets.\nTo permanently allow, run:\n  python3 .claude/hooks/override_cli.py add --rule block_sensitive_file_access --pattern 'YOUR_PATTERN' --label 'Description'",
      "patterns": [
        {
          "pattern": "/etc/(passwd|shadow|sudoers)\\b",
          "label": "System auth files"
        },
        {
          "pattern": "/etc/ssh/ssh_host_[a-z_]+key\\b",
          "label": "SSH host keys"
        },
        {
          "pattern": "~?/?\\.ssh/(id_[a-z]+|authorized_keys|known_hosts|config)\\b",
          "label": "User SSH files"
        },
        {
          "pattern": "~?/?\\.gnupg/",
          "label": "GPG keyring"
        },
        {
          "pattern": "~?/?\\.(bash_history|zsh_history|python_history|mysql_history|psql_history)\\b",
          "label": "Shell/tool history files"
        },
        {
          "pattern": "~?/?\\.(netrc|pgpass|my\\.cnf)\\b",
          "label": "Credential dotfiles (.netrc, .pgpass, .my.cnf)"
        },
        {
          "pattern": "~?/?\\.(env|env\\.local|env\\.production|env\\.staging)\\b",
          "label": "Environment files (.env)"
        },
        {
          "pattern": "~?/?\\.aws/(credentials|config)\\b",
          "label": "AWS credentials file"
        },
        {
          "pattern": "~?/?\\.docker/config\\.json\\b",
          "label": "Docker credentials"
        },
        {
          "pattern": "~?/?\\.kube/config\\b",
          "label": "Kubernetes config"
        },
        {
          "pattern": "~?/?\\.(npmrc|pypirc)\\b",
          "label": "Package manager auth (.npmrc, .pypirc)"
        },
        {
          "pattern": "\\bwallet\\.dat\\b",
          "label": "Crypto wallet file"
        },
        {
          "pattern": "\\b(master\\.key|credentials\\.yml\\.enc)\\b",
          "label": "Rails master key / encrypted credentials"
        }
      ],
      "scf": {
        "domain": "IAC",
        "controls": [
          "IAC-20"
        ],
        "regulations": [
          "GDPR Art.32"
        ],
        "risk_level": "critical"
      },
      "data_classification": "restricted"
    },
    {
      "name": "allow_trusted_endpoints",
      "description": "Allow network calls to trusted hosts",
      "field": "tool_input.command",
      "action": "allow",
      "match": "any",
      "patterns": [
        {
          "pattern": "https?://(localhost|127\\.0\\.0\\.1|0\\.0\\.0\\.0|[^/\\s]*\\.local)[:/\\s'\"]",
          "label": "local"
        },
        {
          "pattern": "https?://((registry\\.)?npmjs\\.(org|com)|(files\\.)?pypi(hosted)?\\.org|rubygems\\.org|crates\\.io|pkg\\.go\\.dev|packagist\\.org)",
          "label": "package registry"
        },
        {
          "pattern": "https?://(github\\.com|gitlab\\.com|bitbucket\\.org)",
          "label": "VCS host"
        }
      ],
      "scf": {
        "domain": "NET",
        "controls": [
          "NET-01"
        ],
        "regulations": [],
        "risk_level": "critical"
      },
      "data_classification": "public"
    },
    {
      "name": "block_untrusted_network",
      "description": "Block network calls to any host not matched by allow_trusted_endpoints above",
      "field": "tool_input.command",
      "action": "ask",
      "overridable": true,
      "match": "any",
      "message": "Network call to untrusted endpoint. Add the host to allow_trusted_endpoints or run:\n  python3 .claude/hooks/override_cli.py add --rule block_untrusted_network --pattern 'https?://your-host' --label 'Your Host'",
      "patterns": [
        {
          "pattern": "\\b(curl|wget|netcat|socat|telnet|nmap)\\b",
          "label": "network tool"
        },
        {
          "pattern": "\\b(ssh|scp)\\b\\s+",
          "label": "remote shell/copy"
        },
        {
          "pattern": "\\brsync\\b\\s+.*:",
          "label": "rsync"
        },
        {
          "pattern": "\\bhttp\\b\\s+(GET|POST|PUT|PATCH|DELETE|HEAD|OPTIONS)",
          "label": "httpie"
        },
        {
          "pattern": "(requests|httpx|axios)\\.(get|post|put|patch|delete|head)\\s*\\(",
          "label": "HTTP library call"
        },
        {
          "pattern": "(urllib\\.request|aiohttp\\.ClientSession|http\\.client\\.HTTP)",
          "label": "Python HTTP client"
        },
        {
          "pattern": "(\\bfetch|https?\\.request)\\s*\\(",
          "label": "JS HTTP call"
        },
        {
          "pattern": "(anthropic|openai)\\.",
          "label": "AI SDK call"
        },
        {
          "pattern": "\\|\\s*(curl|nc|netcat)\\b",
          "label": "pipe to network tool"
        }
      ],
      "scf": {
        "domain": "NET",
        "controls": [
          "NET-01"
        ],
        "regulations": [],
        "risk_level": "critical"
      },
      "data_classification": "internal"
    }
  ]
}
