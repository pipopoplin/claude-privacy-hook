{
  "$schema": "Output sanitizer rules \u2014 same format as filter_rules.json",
  "rules": [
    {
      "name": "redact_api_keys",
      "description": "Redact API keys and tokens in tool output",
      "field": "tool_result.stdout",
      "action": "redact",
      "match": "any",
      "message": "API key or token detected in output.",
      "patterns": [
        {
          "pattern": "sk-ant-[a-zA-Z0-9\\-]+",
          "label": "Anthropic API key"
        },
        {
          "pattern": "sk-(?:proj-)?[a-zA-Z0-9]{20,}",
          "label": "OpenAI-style API key"
        },
        {
          "pattern": "ghp_[a-zA-Z0-9]{36}",
          "label": "GitHub personal access token"
        },
        {
          "pattern": "gho_[a-zA-Z0-9]{36}",
          "label": "GitHub OAuth token"
        },
        {
          "pattern": "xox[bpas]-[a-zA-Z0-9\\-]+",
          "label": "Slack token"
        },
        {
          "pattern": "sk_(live|test)_[a-zA-Z0-9]{24,}",
          "label": "Stripe API key"
        },
        {
          "pattern": "rk_(live|test)_[a-zA-Z0-9]{24,}",
          "label": "Stripe restricted key"
        },
        {
          "pattern": "AIza[0-9A-Za-z\\-_]{35}",
          "label": "Google API key"
        },
        {
          "pattern": "ya29\\.[0-9A-Za-z\\-_]+",
          "label": "Google OAuth token"
        },
        {
          "pattern": "SG\\.[a-zA-Z0-9_\\-]{22}\\.[a-zA-Z0-9_\\-]{43}",
          "label": "SendGrid API key"
        },
        {
          "pattern": "SK[0-9a-fA-F]{32}",
          "label": "Twilio API key"
        },
        {
          "pattern": "AC[0-9a-fA-F]{32}",
          "label": "Twilio Account SID"
        },
        {
          "pattern": "\\beyJ[A-Za-z0-9_-]{10,}\\.eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}",
          "label": "JWT token"
        },
        {
          "pattern": "glpat-[a-zA-Z0-9\\-_]{20,}",
          "label": "GitLab personal access token"
        },
        {
          "pattern": "npm_[a-zA-Z0-9]{36}",
          "label": "npm access token"
        },
        {
          "pattern": "pypi-[a-zA-Z0-9]{60,}",
          "label": "PyPI API token"
        },
        {
          "pattern": "\\bhf_[a-zA-Z0-9]{34}",
          "label": "Hugging Face token"
        },
        {
          "pattern": "\\bDOPAT[a-zA-Z0-9_\\-]{40,}",
          "label": "DigitalOcean personal access token"
        },
        {
          "pattern": "(aws_access_key_id|aws_secret_access_key)\\s*=\\s*['\"]?[A-Z0-9]",
          "label": "AWS credentials"
        },
        {
          "pattern": "AKIA[0-9A-Z]{16}",
          "label": "AWS access key ID"
        }
      ],
      "scf": {
        "domain": "IAC",
        "controls": [
          "IAC-01"
        ],
        "regulations": [
          "GDPR Art.32"
        ],
        "risk_level": "critical"
      },
      "data_classification": "confidential"
    },
    {
      "name": "redact_email_addresses",
      "description": "Redact email addresses in tool output",
      "field": "tool_result.stdout",
      "action": "redact",
      "match": "any",
      "message": "Email address detected in output.",
      "patterns": [
        {
          "pattern": "\\b[A-Za-z0-9._%+\\-]+@[A-Za-z0-9.\\-]+\\.[A-Za-z]{2,}\\b",
          "label": "Email address"
        }
      ],
      "scf": {
        "domain": "PRI",
        "controls": [
          "PRI-01"
        ],
        "regulations": [
          "GDPR Art.4"
        ],
        "risk_level": "high"
      },
      "data_classification": "confidential"
    },
    {
      "name": "redact_internal_ip_addresses",
      "description": "Redact private/internal IP addresses in tool output",
      "field": "tool_result.stdout",
      "action": "redact",
      "match": "any",
      "message": "Internal IP address detected in output.",
      "patterns": [
        {
          "pattern": "\\b10\\.\\d{1,3}\\.\\d{1,3}\\.\\d{1,3}\\b",
          "label": "RFC1918 Class A (10.x.x.x)"
        },
        {
          "pattern": "\\b172\\.(1[6-9]|2[0-9]|3[01])\\.\\d{1,3}\\.\\d{1,3}\\b",
          "label": "RFC1918 Class B (172.16-31.x.x)"
        },
        {
          "pattern": "\\b192\\.168\\.\\d{1,3}\\.\\d{1,3}\\b",
          "label": "RFC1918 Class C (192.168.x.x)"
        },
        {
          "pattern": "\\b169\\.254\\.\\d{1,3}\\.\\d{1,3}\\b",
          "label": "Link-local address (169.254.x.x)"
        },
        {
          "pattern": "\\bfd[0-9a-f]{2}:[0-9a-f:]+\\b",
          "label": "IPv6 ULA (fdxx:)"
        },
        {
          "pattern": "\\bfe80::[0-9a-f:]+\\b",
          "label": "IPv6 link-local (fe80::)"
        }
      ],
      "scf": {
        "domain": "NET",
        "controls": [
          "NET-01"
        ],
        "regulations": [
          "GDPR Art.32"
        ],
        "risk_level": "high"
      },
      "data_classification": "internal"
    }
  ]
}
