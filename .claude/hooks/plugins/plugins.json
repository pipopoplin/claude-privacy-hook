{
  "plugins": {
    "presidio": {
      "module": "plugins.presidio_plugin",
      "class": "PresidioPlugin",
      "tier": "SubMillisecond",
      "latency": "~0.4ms",
      "description": "Microsoft Presidio — known PII types, max speed",
      "install": "pip install presidio-analyzer"
    },
    "distilbert": {
      "module": "plugins.distilbert_plugin",
      "class": "DistilBERTPlugin",
      "tier": "HighAccuracy",
      "latency": "~25ms",
      "description": "DistilBERT / NerGuard — best accuracy NER",
      "install": "pip install transformers torch"
    },
    "spacy": {
      "module": "plugins.spacy_plugin",
      "class": "SpaCyPlugin",
      "tier": "EdgeDevice",
      "latency": "~3ms",
      "description": "spaCy sm + regex — edge/low-resource",
      "install": "pip install spacy && python -m spacy download en_core_web_sm"
    },
    "prompt_injection": {
      "module": "plugins.prompt_injection_plugin",
      "class": "PromptInjectionPlugin",
      "tier": "EdgeDevice",
      "latency": "~1ms",
      "description": "Prompt injection / jailbreak detection — heuristic + keyword",
      "install": "No extra dependencies"
    },
    "sensitive_categories": {
      "module": "plugins.sensitive_categories_plugin",
      "class": "SensitiveCategoriesPlugin",
      "tier": "EdgeDevice",
      "latency": "~1ms",
      "description": "Medical, biometric, and protected category data detection — keyword + context",
      "install": "No extra dependencies"
    },
    "entropy_detector": {
      "module": "plugins.entropy_detector_plugin",
      "class": "EntropyDetectorPlugin",
      "tier": "EdgeDevice",
      "latency": "~1ms",
      "description": "High-entropy string detection for unknown secret formats",
      "install": "No extra dependencies"
    },
    "semantic_intent": {
      "module": "plugins.semantic_intent_plugin",
      "class": "SemanticIntentPlugin",
      "tier": "EdgeDevice",
      "latency": "~1ms",
      "description": "Verb+target heuristic classification for suspicious command intent",
      "install": "No extra dependencies"
    }
  }
}
