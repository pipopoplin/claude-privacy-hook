{
  "enabled": true,
  "plugin_priority": ["presidio", "spacy", "distilbert"],
  "supplementary_plugins": ["prompt_injection", "sensitive_categories", "entropy_detector", "semantic_intent"],
  "fallback_strategy": "first_available",
  "field": "tool_input.command",
  "min_confidence": 0.7,
  "action": "deny",
  "entity_types": [
    "PERSON", "EMAIL_ADDRESS", "PHONE_NUMBER",
    "US_SSN", "CREDIT_CARD", "IP_ADDRESS",
    "PROMPT_INJECTION",
    "MEDICAL_DATA", "BIOMETRIC_DATA", "PROTECTED_CATEGORY",
    "HIGH_ENTROPY_SECRET",
    "SUSPICIOUS_INTENT"
  ],
  "plugins": {
    "presidio": {
      "enabled": true,
      "languages": ["en"],
      "score_threshold": 0.6
    },
    "distilbert": {
      "enabled": true,
      "model": "dslim/distilbert-NER",
      "score_threshold": 0.8
    },
    "spacy": {
      "enabled": true,
      "model": "en_core_web_sm",
      "extra_patterns": true
    },
    "prompt_injection": {
      "enabled": true,
      "score_threshold": 0.6
    },
    "sensitive_categories": {
      "enabled": true,
      "categories": ["medical", "biometric", "protected_category"]
    },
    "entropy_detector": {
      "enabled": true,
      "min_entropy": 4.0,
      "min_length": 16
    },
    "semantic_intent": {
      "enabled": true
    }
  }
}
